# --- Autonomous AI Job Search Agent — example environment ---
# Copy to .env and fill in. NEVER commit .env.

# LLM (Anthropic Claude)
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql://jobagent:jobagent@localhost:5432/jobagent
# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth (Gmail + Calendar) — added in Sprint 4
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/oauth/google/callback

# App config
AUTONOMY_MODE=hitl            # hitl | semi
MONTHLY_USD_CAP=50            # hard LLM budget cap
BUDGET_ALERT_PCT=0.8
DAILY_APPLICATION_CAP=10
STORAGE_ROOT=./storage        # filesystem-mcp sandbox root
LOG_LEVEL=info

# Discovery
SOURCES_FILE=./config/sources.json   # file-based source config (until DB/dashboard store)
DISCOVERY_CRON=*/30 * * * *          # worker repeatable schedule
# NOTE: if a native Redis already runs on 6379, the compose `redis` service will conflict.
# Either stop the native one or point REDIS_URL at it (the worker uses REDIS_URL).

# Models (config-driven; swap without code changes)
MODEL_REASONING=claude-opus-4-8
MODEL_CHEAP=claude-haiku-4-5-20251001
EMBEDDING_MODEL=local-hash    # placeholder; swap for a real embedding provider
EMBEDDING_DIM=1536
